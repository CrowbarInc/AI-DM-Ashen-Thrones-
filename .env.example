## Copy this file to `.env` and fill in values.
## Never commit your real `.env` to source control.

# Required (no defaults)
OPENAI_API_KEY=

# Optional model configuration (defaults exist in code)
# Legacy compatibility knob. Existing `.env` files with only `MODEL_NAME`
# continue to work, but `DEFAULT_MODEL_NAME` is the new primary knob.
MODEL_NAME=gpt-4o-mini
DEFAULT_MODEL_NAME=gpt-4o-mini
HIGH_PRECISION_MODEL_NAME=gpt-4.1-mini
RETRY_ESCALATION_MODEL_NAME=gpt-4.1-mini
ENABLE_MODEL_ROUTING=true

